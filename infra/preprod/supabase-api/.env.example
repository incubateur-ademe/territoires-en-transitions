# Variables d'environnement de la stack supabase-api Coolify.
# À reporter dans l'onglet "Environment Variables" du Compose dans Coolify,
# en marquant comme secret tout ce qui contient _SECRET, _KEY, _PASS, _URL.

# === Application URL ===
API_EXTERNAL_URL=https://supabase-api.preprod.territoiresentransitions.fr
GOTRUE_SITE_URL=https://app.preprod.territoiresentransitions.fr
GOTRUE_URI_ALLOW_LIST=https://app.preprod.territoiresentransitions.fr,https://auth.preprod.territoiresentransitions.fr,https://backend.preprod.territoiresentransitions.fr,https://panier.preprod.territoiresentransitions.fr,https://site.preprod.territoiresentransitions.fr

# === JWT et clés Supabase ===
# Récupérer depuis le dashboard Supabase preprod actuel :
#   Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=
#   Settings → API → Project API keys → anon (public)
SUPABASE_ANON_KEY=
#   Settings → API → Project API keys → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# === Connexions Postgres ===
# Format : postgres://<role>:<pwd>@<pg-private-ip>:5432/postgres?sslmode=require&search_path=<schema>
# L'IP privée vient de : terraform output -raw pg_private_endpoint_ip
#
# Les rôles supabase_auth_admin / supabase_storage_admin sont créés par
# sql/001-bootstrap-auth-roles.sql avec les mots de passe que tu choisis. Reporter
# ici les MÊMES mots de passe que ceux passés à psql -v auth_admin_pwd=... etc.

GOTRUE_DB_DATABASE_URL=
STORAGE_DB_DATABASE_URL=

# === SMTP Brevo ===
# Port 2525 imposé par le compose (Scaleway bloque 25/465/587 par défaut).
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_SENDER_EMAIL=notifications@territoiresentransitions.fr
BREVO_SMTP_SENDER_NAME=Territoires en Transitions

# === Scaleway Object Storage ===
# Créer le bucket via la console (ou ajouter un module TF), puis générer une
# clé IAM dédiée avec ObjectStorageFullAccess sur ce bucket.
SCW_S3_BUCKET=tet-preprod-storage
SCW_ACCESS_KEY_ID=
SCW_SECRET_ACCESS_KEY=
