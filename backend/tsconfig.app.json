{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "outDir": "./dist/app",
    "rootDir": "src",
    // "module": "NodeNext",
    // "moduleResolution": "NodeNext",
    "paths": {
      "@/backend/*": ["./src/*"]
    },
  },
  "exclude": [
    "vitest.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.e2e-spec.ts",
    "src/**/*.test.ts"
  ],
  "include": ["src/**/*.ts"]
}
