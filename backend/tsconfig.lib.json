{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "outDir": "dist/lib",
    "rootDir": "src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "@/backend/*": ["./src/*"],
      "@/backend/test": ["./test/index"]
    },
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vitest.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.e2e-spec.ts",
    "src/**/*.test.ts",
    "src/main.ts",
    "src/**/*.service.ts",
    "src/**/*.controller.ts",
    "src/**/*.module.ts",
    "src/**/*.router.ts",
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
