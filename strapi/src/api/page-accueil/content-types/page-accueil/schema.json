{
  "kind": "singleType",
  "collectionName": "page_accueils",
  "info": {
    "singularName": "page-accueil",
    "pluralName": "page-accueils",
    "displayName": "1. Accueil",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "Titre": {
      "type": "string",
      "required": true,
      "default": "Accélérez la transition écologique de votre collectivité",
      "maxLength": 100
    },
    "Couverture": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "Accompagnement": {
      "type": "component",
      "repeatable": false,
      "component": "bloc.accompagnement",
      "required": true
    },
    "Temoignages": {
      "type": "component",
      "repeatable": false,
      "component": "bloc.description",
      "required": true
    },
    "temoignages_liste": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::temoignage.temoignage"
    },
    "Informations": {
      "type": "component",
      "repeatable": false,
      "component": "bloc.description",
      "required": true
    },
    "informations_titre": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "informations_cta": {
      "type": "component",
      "repeatable": true,
      "component": "shared.vignette-avec-bouton",
      "required": true,
      "max": 3,
      "min": 1
    },
    "Newsletter": {
      "type": "component",
      "repeatable": false,
      "component": "bloc.description",
      "required": true
    },
    "newsletter_cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.bouton-avec-lien",
      "required": true
    }
  }
}
