{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "vitest"
    ]
  },
  "include": [
    "vitest.config.mts",
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.test-fixture.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../backend/tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.lib.json"
    },

  ]
}
