{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    // "composite": true,
    // "declaration": true,
    // "declarationMap": true,
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    // "module": "NodeNext",
    // "moduleResolution": "NodeNext",
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "**/*.test.ts",
    "**/*.service.ts",
    "**/*.controller.ts",
    "**/*.module.ts",
    "**/*.router.ts",
    "**/*.decorator.ts",
    "**/*.interceptor.ts"
  ]
}
